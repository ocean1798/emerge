PORT=8787

# Any OpenAI-compatible chat API.
# OpenAI example:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=your_openai_chat_model
#
# DeepSeek example:
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-v4-flash
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=replace_with_your_openai_compatible_api_key
OPENAI_MODEL=deepseek-v4-flash
OPENAI_PROVIDER_LABEL=DeepSeek
OPENAI_CHAT_PATH=/chat/completions
OPENAI_EXTRA_BODY_JSON={}
# Optional, only when the provider requires them:
# OPENAI_ORGANIZATION=
# OPENAI_PROJECT=

# Ollama local embedding API
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=embeddinggemma
